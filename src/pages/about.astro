---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description="About Karim Akoudad." />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<p>
				I'm Akoudad. This is where I write about my ideas, opinions, things I make
				and learn, reviews, art... Technical and not.
			</p>
			<p>Writing is how I think things through.</p>
			<p>
				Find me on <a href="https://github.com/akoudad" target="_blank" rel="me noopener"
					>GitHub</a
				>. New posts have an <a href="/rss.xml">RSS feed</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
